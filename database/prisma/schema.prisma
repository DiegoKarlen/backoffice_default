// Single-tenant backoffice: users, roles, functionalities (RBAC).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  active       Boolean    @default(true)
  roles        UserRole[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bingosCreated Bingo[] @relation("BingoCreatedBy")
  bingosUpdated Bingo[] @relation("BingoUpdatedBy")
}

model Role {
  id              String                @id @default(uuid())
  code            String                @unique
  name            String
  description     String?
  users           UserRole[]
  functionalities RoleFunctionality[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model Functionality {
  id          String                @id @default(uuid())
  code        String                @unique
  name        String
  description String?
  /// Grouping for menus or feature flags per product area.
  module      String?
  roles       RoleFunctionality[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RoleFunctionality {
  roleId          String
  functionalityId String
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  functionality   Functionality   @relation(fields: [functionalityId], references: [id], onDelete: Cascade)

  @@id([roleId, functionalityId])
}

enum BingoType {
  BINGO_75
  BINGO_90
}

enum BingoStatus {
  ACTIVE
  INACTIVE
}

// --- Bingo (simplified) ---

enum BingoFigure {
  LINE
  PERIMETER
  FULL_HOUSE
}

model Bingo {
  id                 String      @id @default(uuid())
  roomName           String
  status             BingoStatus @default(INACTIVE)
  bingoType          BingoType
  startDateTime      DateTime
  repeatEveryMinutes Int?
  cardPrice          Decimal     @db.Decimal(14, 4)
  minPlayersToStart  Int         @default(2)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  createdByUserId    String?
  updatedByUserId    String?
  createdBy          User?       @relation("BingoCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy          User?       @relation("BingoUpdatedBy", fields: [updatedByUserId], references: [id])
  prizes             BingoPrize[]

  @@index([status])
  @@index([startDateTime])
  @@index([bingoType])
}

model BingoPrize {
  id        String     @id @default(uuid())
  bingoId   String
  bingo     Bingo      @relation(fields: [bingoId], references: [id], onDelete: Cascade)
  figure    BingoFigure
  amount    Decimal    @db.Decimal(14, 4)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([bingoId, figure])
  @@index([bingoId])
}
