# URL absoluta de la API (misma que el backoffice). Ejemplo:
# VITE_API_URL=http://localhost:4001
#
# Si no definís VITE_API_URL en desarrollo, se usa el proxy de Vite:
# las peticiones van a /api/... y vite.config.ts reenvía a localhost:4001.
# Para forzar URL absoluta en dev: definí VITE_API_URL.
#
# Puerto alternativo del proxy (opcional):
# VITE_PROXY_TARGET=http://localhost:4001
