# Copy to api/.env and adjust.

DATABASE_URL="postgresql://user:password@localhost:5432/generic_admin?schema=public"

# API
PORT=4001

# Motor bingo público (/public/bingos/live/*) — opcional
# BINGO_DRAW_INTERVAL_MS=2200
# Reconsultar agenda si no hay ocurrencias en horizonte (ms)
# BINGO_SCHEDULER_POLL_MS=60000

# Auditoría RNG (revisión tipo GLI / trazabilidad) — opcional
# BINGO_RNG_AUDIT_LOG=1
# BINGO_RNG_AUDIT_VERBOSE=1

JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_EXPIRES_IN="8h"

# Default project for seed (code must match a row in Project after seed)
SEED_PROJECT_CODE="default"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# --- bingo-display (opcional): copiar bingo-display/.env.example → bingo-display/.env y definir VITE_API_URL si no usás el proxy de Vite en dev.
